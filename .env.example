# Set these in the Netlify site UI (Site settings → Environment variables).
# Local dev: copy to .env and run `netlify dev`.

# Notion internal integration token (starts with "ntn_" / "secret_").
NOTION_TOKEN=

# Database IDs (32-char hex, from the database URL). Share both DBs with the integration.
NOTION_SOAP_DB_ID=
NOTION_CURE_DB_ID=

# Google OAuth — owner write auth (public read).
# Reuse olive_grove's OAuth Web client; add soap.usfkhoury.com as an authorized
# JavaScript origin. The client ID also goes in index.html (<meta google-client-id>).
GOOGLE_CLIENT_ID=
# Only this Google account may write batches / cure weights.
OWNER_EMAIL=
